<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Photobooth.App.Views"
        xmlns:vm="clr-namespace:Photobooth.App.ViewModels"
        x:Class="Photobooth.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="{Binding DesignWidth, FallbackValue=1280}"
        Height="{Binding DesignHeight, FallbackValue=720}"
        Title="Photobooth"
        Background="Black">
  <views:MainView />
</Window>
